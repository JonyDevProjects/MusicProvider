{
  "version": "1.0.0",
  "project": "MusicProvider",
  "description": "OpenSpec — Spec-Driven Development artifacts for MusicProvider",
  "sdd": {
    "enabled": true,
    "strict_tdd": true,
    "test_command": "npm run test",
    "build_command": "npm run build"
  },
  "conventions": {
    "spec_format": "markdown",
    "required_sections": [
      "Contexto",
      "Diseño",
      "Archivos afectados",
      "Criterios de aceptación"
    ]
  }
}
