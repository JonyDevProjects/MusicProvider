{
  "name": "music-provider",
  "version": "1.0.0",
  "description": "Standalone music provider utilizing yt-dlp to search, fetch streams and download tracks",
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev:server": "tsx src/server.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report tests/e2e-report"
  },
  "dependencies": {
    "adm-zip": "^0.5.14",
    "axios": "^1.7.2",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.9",
    "tsx": "^4.16.2",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
